# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# SQL Server SA password (min 8 chars, upper+lower+digit+symbol)
SA_PASSWORD=YourStrong!Passw0rd

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Secret passed in X-Telegram-Bot-Api-Secret-Token header (any random string)
TELEGRAM_WEBHOOK_SECRET=change_me_random_secret

# Telegram chat ID of the primary admin account
TELEGRAM_ADMIN_CHAT_ID=123456789

# Optional: Telegram channel ID for backup notifications (0 = disabled)
TELEGRAM_BACKUP_CHANNEL_ID=0
